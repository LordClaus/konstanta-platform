# ──────────────────────────────────────────────────────────────────────────────
# NOTE: The bot no longer runs as a standalone process. It runs IN-PROCESS inside
# the FastAPI service (webhook in prod, polling locally). Therefore its environment
# variables live in the API service env — see ../.env.example:
#
#   BOT_TOKEN, MANAGER_GROUP_ID, ADMIN_IDS, BOT_PROVISION_SECRET, PUBLIC_URL
#
# The bot reaches the API over HTTP using API_BASE_URL (set it to the API's public
# URL in prod, e.g. https://<svc>.koyeb.app; http://localhost:8000 locally).
# This file is kept only as a reference; you do not need a separate telegram_bot/.env.
# ──────────────────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
WS_RECONNECT_DELAY=5.0
