# ── База даних Turso ──────────────────────────────────────────────────────────
# Get these from the Turso dashboard (`turso db show` / `turso db tokens create`).
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ── JWT (staff + candidate auth) ──────────────────────────────────────────────
# REQUIRED. Long random secret used to sign access tokens (HS256).
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_to_a_long_random_secret

# ── Google OAuth ──────────────────────────────────────────────────────────────
# OAuth 2.0 Web Client ID; the backend verifies Google ID tokens against it.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Telegram bot (runs IN-PROCESS inside this API service) ────────────────────
# The bot lives in the API process. Webhook mode when PUBLIC_URL is set (prod),
# otherwise long-polling (local dev). Leave BOT_TOKEN empty to run the API without
# the bot.
BOT_TOKEN=your_bot_token_from_botfather
MANAGER_GROUP_ID=-1001234567890
# Comma-separated owner Telegram IDs allowed to run /addstaff:
ADMIN_IDS=123456789,987654321
# Public HTTPS URL of THIS service (e.g. https://<svc>.koyeb.app). Set in prod to
# enable the Telegram webhook (PUBLIC_URL/telegram/webhook). Unset → polling.
PUBLIC_URL=
# Base URL the in-process bot uses for its own HTTP calls (/jobs, /apply).
# Prod: same as PUBLIC_URL. Local: http://localhost:8000.
API_BASE_URL=http://localhost:8000
# Reused as the staff-provisioning secret AND the Telegram webhook secret_token.
BOT_PROVISION_SECRET=change_me_to_a_long_random_secret

# ── Cloudflare R2 (S3-compatible object storage for job photos) ───────────────
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_KEY=your_r2_access_key_id
R2_SECRET=your_r2_secret_access_key
R2_BUCKET=konstanta-jobs
R2_PUBLIC_URL=https://your-public-r2-domain

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash).
ALLOWED_ORIGINS=https://www.konstanta-agency.cz

# ── Налаштування сервера ──────────────────────────────────────────────────────
PORT=8000
# Set to 1 only for local development; MUST be 0 (or unset) in production.
DEV_RELOAD=0
