# ── Secrets / environment ─────────────────────────────────────────────────────
# NEVER commit real .env files. Only *.env.example (with placeholder values) is tracked.
.env
*.env
!*.env.example
**/.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── Coverage artifacts ────────────────────────────────────────────────────────
.coverage
.coverage.*
htmlcov/
coverage.xml

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Databases (local SQLite; never commit data) ──────────────────────────────
*.db
*.db-journal
*.sqlite3

# ── Local-only notes (never published) ───────────────────────────────────────
*.local.md

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
