# ── Copy to .env and fill in. Compose reads this file automatically. ──────────

# ── Database (async SQLAlchemy URL) ───────────────────────────────────────────
# PostgreSQL in production/compose; SQLite is used automatically by the tests.
DATABASE_URL=postgresql+asyncpg://konstanta:konstanta@db:5432/konstanta

# ── Auth ──────────────────────────────────────────────────────────────────────
# Use a long random string (>= 32 bytes). Generate: `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-secret-min-32-bytes
GOOGLE_CLIENT_ID=

# ── CORS (comma-separated frontend origins) ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5500

# ── AI assistant ──────────────────────────────────────────────────────────────
# AI_PROVIDER selects the vendor; the other is used as a fallback if it has a key.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Email (Brevo transactional API) ───────────────────────────────────────────
BREVO_API_KEY=
MAIL_FROM=
MAIL_FROM_NAME=Konstanta

# ── Telegram bot (optional; disabled when BOT_TOKEN is empty) ─────────────────
BOT_TOKEN=
BOT_PROVISION_SECRET=
# Public HTTPS URL of this service; set → webhook mode, unset → long-polling.
PUBLIC_URL=

# ── Object storage for job photos (Cloudflare R2 / S3-compatible; optional) ───
R2_ENDPOINT=
R2_KEY=
R2_SECRET=
R2_BUCKET=
R2_PUBLIC_URL=
